# 数据库配置
DATABASE_URL="mysql://root:root@localhost:3306/zhige_dockyard?charset=utf8mb4"

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET="zhige-dockyard-jwt-secret-key-2024-change-this"

# 系统初始化令牌（首次部署时设置，用于保护初始化接口）
SETUP_TOKEN="zhige-init-2024-secure-token"

# 短信服务配置（以阿里云为例）
SMS_PROVIDER="aliyun"
SMS_ACCESS_KEY_ID=""
SMS_ACCESS_KEY_SECRET=""
SMS_SIGN_NAME="知阁.舟坊"
SMS_VERIFY_CODE_TEMPLATE_ID=""

# 微信 OAuth2.0 配置
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_REDIRECT_URI=""

# QQ OAuth2.0 配置
QQ_APP_ID=""
QQ_APP_KEY=""
QQ_REDIRECT_URI=""

# Redis 配置（用于缓存验证码等）
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
