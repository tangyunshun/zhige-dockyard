# 数据库配置
DATABASE_URL="mysql://root:password@localhost:3306/zhige_dockyard?charset=utf8mb4"

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# 系统初始化令牌（首次部署时设置，用于保护初始化接口）
SETUP_TOKEN="zhige-dockyard-setup-token-2024"

# 短信服务配置（以阿里云为例）
SMS_PROVIDER="aliyun"
SMS_ACCESS_KEY_ID=""
SMS_ACCESS_KEY_SECRET=""
SMS_SIGN_NAME="知阁舟坊"
SMS_VERIFY_CODE_TEMPLATE_ID=""

# 微信 OAuth2.0 配置
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_REDIRECT_URI=""

# QQ OAuth2.0 配置
QQ_APP_ID=""
QQ_APP_KEY=""
QQ_REDIRECT_URI=""

# Redis 配置（用于缓存验证码等）
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
