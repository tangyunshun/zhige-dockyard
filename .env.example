# ==================== 数据库配置 ====================
DATABASE_URL="mysql://root:your_password@localhost:3306/zhige_dockyard"

# ==================== JWT 配置 ====================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# ==================== 微信登录配置 ====================
# 正式环境：填写真实的微信开放平台 AppID 和 AppSecret
# 测试环境：留空或使用 wx1234567890 即可自动启用测试模式
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_REDIRECT_URI="http://localhost:3000/api/auth/wechat/callback"

# ==================== QQ 登录配置 ====================
# 正式环境：填写真实的 QQ 互联 AppID 和 AppKey
# 测试环境：留空或使用 1234567890 即可自动启用测试模式
QQ_APP_ID=""
QQ_APP_KEY=""
QQ_REDIRECT_URI="http://localhost:3000/api/auth/qq/callback"

# ==================== 其他配置 ====================
# 生产环境请设置为 production
NODE_ENV="development"
