generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model componenttask {
  id          String    @id
  name        String
  description String?
  type        String
  status      String    @default("pending")
  progress    Int       @default(0)
  config      Json?
  result      Json?
  userId      String?
  tenantId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  category    String?
  icon        String?
  isPublished Boolean   @default(false)
  sortOrder   Int       @default(0)
  tags        String?
  usageCount  Int       @default(0)
  tenant      tenant?   @relation(fields: [tenantId], references: [id], map: "ComponentTask_tenantId_fkey")
  user        user?     @relation(fields: [userId], references: [id], map: "ComponentTask_userId_fkey")

  @@index([status], map: "ComponentTask_status_idx")
  @@index([isPublished], map: "ComponentTask_isPublished_idx")
  @@index([type], map: "ComponentTask_type_idx")
  @@index([category], map: "ComponentTask_category_idx")
  @@index([sortOrder], map: "ComponentTask_sortOrder_idx")
  @@index([tenantId], map: "ComponentTask_tenantId_idx")
  @@index([userId], map: "ComponentTask_userId_idx")
}

model tenant {
  id            String          @id
  name          String
  description   String?
  logo          String?
  status        String          @default("active")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  componenttask componenttask[]
  user          user[]

  @@index([name], map: "Tenant_name_idx")
  @@index([status], map: "Tenant_status_idx")
}

model user {
  id                                                       String                @id @default(cuid())
  email                                                    String?               @unique(map: "User_email_key")
  name                                                     String?
  password                                                 String
  avatar                                                   String?
  role                                                     String                @default("user")
  tenantId                                                 String?
  createdAt                                                DateTime              @default(now())
  updatedAt                                                DateTime              @updatedAt
  lastWorkspaceId                                          String?               @map("last_workspace_id")
  lockedUntil                                              DateTime?
  loginAttempts                                            Int                   @default(0)
  phone                                                    String?               @unique(map: "User_phone_key")
  qqUnionId                                                String?               @unique(map: "User_qqUnionId_key")
  refreshToken                                             String?
  refreshTokenExpiresAt                                    DateTime?
  status                                                   UserStatus            @default(active)
  wechatUnionId                                            String?               @unique(map: "User_wechatUnionId_key")
  membershipLevel                                          String                @default("FREE")
  lastForcedLogoutAt                                       DateTime?             @map("last_forced_logout_at")
  lastLoginAt                                              DateTime?             @map("last_login_at")
  sessionExpiresAt                                         DateTime?             @map("session_expires_at")
  sessionToken                                             String?               @map("session_token")
  apikey                                                   apikey[]
  componentrating                                          componentrating[]
  componentreview                                          componentreview[]
  componenttask                                            componenttask[]
  loginhistory                                             loginhistory[]
  membershipchangelog_membershipchangelog_operatorIdTouser membershipchangelog[] @relation("membershipchangelog_operatorIdTouser")
  membershipchangelog_membershipchangelog_userIdTouser     membershipchangelog[] @relation("membershipchangelog_userIdTouser")
  membershiporder                                          membershiporder[]
  operationlog                                             operationlog[]
  systemdocument                                           systemdocument[]
  upgradeapplication                                       upgradeapplication[]
  tenant                                                   tenant?               @relation(fields: [tenantId], references: [id], map: "User_tenantId_fkey")
  usernotification                                         usernotification?
  userpreference                                           userpreference?
  workspacemember                                          workspacemember[]

  @@index([email], map: "User_email_idx")
  @@index([phone], map: "User_phone_idx")
  @@index([tenantId], map: "User_tenantId_idx")
  @@index([status], map: "User_status_idx")
  @@index([role], map: "User_role_idx")
  @@index([lastWorkspaceId], map: "User_lastWorkspaceId_idx")
}

model apikey {
  id          String    @id
  userId      String
  name        String
  description String?
  keyHash     String
  keyPrefix   String
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  user        user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ApiKey_userId_fkey")

  @@index([keyPrefix], map: "ApiKey_keyPrefix_idx")
  @@index([userId], map: "ApiKey_userId_idx")
}

model asset {
  id          String   @id
  workspaceId String
  name        String
  type        String
  url         String?
  metadata    Json?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([type], map: "Asset_type_idx")
  @@index([workspaceId], map: "Asset_workspaceId_idx")
}

model componentfavorite {
  id          String   @id
  userId      String
  componentId String
  createdAt   DateTime @default(now())

  @@unique([userId, componentId], map: "ComponentFavorite_userId_componentId_key")
  @@index([componentId], map: "ComponentFavorite_componentId_idx")
  @@index([userId], map: "ComponentFavorite_userId_idx")
}

model componentrating {
  id          String   @id
  userId      String
  componentId String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ComponentRating_userId_fkey")

  @@unique([userId, componentId], map: "ComponentRating_userId_componentId_key")
  @@index([componentId], map: "ComponentRating_componentId_idx")
  @@index([rating], map: "ComponentRating_rating_idx")
}

model componentreview {
  id                    String            @id
  userId                String
  componentId           String
  parentId              String?
  content               String
  rating                Int?
  status                String            @default("active")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime
  componentreview       componentreview?  @relation("componentreviewTocomponentreview", fields: [parentId], references: [id], map: "ComponentReview_parentId_fkey")
  other_componentreview componentreview[] @relation("componentreviewTocomponentreview")
  user                  user              @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ComponentReview_userId_fkey")

  @@index([componentId], map: "ComponentReview_componentId_idx")
  @@index([parentId], map: "ComponentReview_parentId_idx")
  @@index([status], map: "ComponentReview_status_idx")
  @@index([userId], map: "ComponentReview_userId_fkey")
}

model componentstats {
  id             String    @id
  componentId    String    @unique(map: "ComponentStats_componentId_key")
  totalUses      Int       @default(0)
  totalFavorites Int       @default(0)
  averageRating  Float     @default(0)
  ratingCount    Int       @default(0)
  reviewCount    Int       @default(0)
  dailyUses      Int       @default(0)
  weeklyUses     Int       @default(0)
  monthlyUses    Int       @default(0)
  lastUsedAt     DateTime?
  updatedAt      DateTime

  @@index([averageRating], map: "ComponentStats_averageRating_idx")
  @@index([componentId], map: "ComponentStats_componentId_idx")
  @@index([totalUses], map: "ComponentStats_totalUses_idx")
}

model componentusage {
  id          String   @id
  userId      String
  componentId String
  workspaceId String?
  usedAt      DateTime @default(now())
  metadata    Json?

  @@index([componentId], map: "ComponentUsage_componentId_idx")
  @@index([usedAt], map: "ComponentUsage_usedAt_idx")
  @@index([userId], map: "ComponentUsage_userId_idx")
}

model conversation {
  id          String   @id
  workspaceId String
  userId      String
  title       String?
  messages    Json?
  model       String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([userId], map: "Conversation_userId_idx")
  @@index([workspaceId], map: "Conversation_workspaceId_idx")
}

model document {
  id          String   @id
  workspaceId String
  title       String
  content     String?
  parentId    String?
  type        String   @default("doc")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([parentId], map: "Document_parentId_idx")
  @@index([status], map: "Document_status_idx")
  @@index([workspaceId], map: "Document_workspaceId_idx")
}

model integration {
  id          String   @id
  workspaceId String
  provider    String
  tokenHash   String
  name        String?
  configured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@unique([workspaceId, provider], map: "Integration_workspaceId_provider_key")
  @@index([workspaceId], map: "Integration_workspaceId_idx")
}

model loginhistory {
  id        String   @id
  userId    String
  ipAddress String?
  userAgent String?
  location  String?
  device    String?
  loginAt   DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "LoginHistory_userId_fkey")

  @@index([loginAt], map: "LoginHistory_loginAt_idx")
  @@index([userId], map: "LoginHistory_userId_idx")
}

model membershipchangelog {
  id                                        String           @id
  userId                                    String
  levelId                                   String?
  operatorId                                String?
  changeType                                String
  oldValue                                  Json?
  newValue                                  Json
  reason                                    String?
  createdAt                                 DateTime         @default(now())
  membershiplevel                           membershiplevel? @relation(fields: [levelId], references: [id], map: "MembershipChangeLog_levelId_fkey")
  user_membershipchangelog_operatorIdTouser user?            @relation("membershipchangelog_operatorIdTouser", fields: [operatorId], references: [id], map: "MembershipChangeLog_operatorId_fkey")
  user_membershipchangelog_userIdTouser     user             @relation("membershipchangelog_userIdTouser", fields: [userId], references: [id], map: "MembershipChangeLog_userId_fkey")

  @@index([changeType], map: "MembershipChangeLog_changeType_idx")
  @@index([createdAt], map: "MembershipChangeLog_createdAt_idx")
  @@index([levelId], map: "MembershipChangeLog_levelId_fkey")
  @@index([operatorId], map: "MembershipChangeLog_operatorId_idx")
  @@index([userId], map: "MembershipChangeLog_userId_idx")
}

model membershiplevel {
  id                      String                @id
  name                    String                @unique(map: "MembershipLevel_name_key")
  nameZh                  String
  icon                    String?
  color                   String                @default("#94a3b8")
  description             String?
  maxPersonalWorkspaces   Int                   @default(1)
  maxEnterpriseWorkspaces BigInt                @default(1)
  maxComponents           BigInt                @default(100)
  maxTeamSize             BigInt                @default(5)
  maxStorage              BigInt                @default(1073741824)
  maxApiCalls             BigInt                @default(1000)
  features                Json?
  priceMonthly            Int                   @default(0)
  priceYearly             Int                   @default(0)
  trialDays               Int                   @default(0)
  sortOrder               Int                   @default(0)
  isActive                Boolean               @default(true)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime
  isPopular               Boolean               @default(false)
  isRecommended           Boolean               @default(false)
  membershipchangelog     membershipchangelog[]
  membershiporder         membershiporder[]

  @@index([isActive], map: "MembershipLevel_isActive_idx")
  @@index([name], map: "MembershipLevel_name_idx")
  @@index([sortOrder], map: "MembershipLevel_sortOrder_idx")
}

model membershiporder {
  id              String          @id
  userId          String
  levelId         String
  orderType       String          @default("NEW")
  paymentMethod   String?
  amount          Int             @default(0)
  currency        String          @default("CNY")
  startDate       DateTime
  endDate         DateTime
  status          String          @default("PENDING")
  transactionId   String?
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  membershiplevel membershiplevel @relation(fields: [levelId], references: [id], map: "MembershipOrder_levelId_fkey")
  user            user            @relation(fields: [userId], references: [id], map: "MembershipOrder_userId_fkey")

  @@index([createdAt], map: "MembershipOrder_createdAt_idx")
  @@index([levelId], map: "MembershipOrder_levelId_idx")
  @@index([status], map: "MembershipOrder_status_idx")
  @@index([userId], map: "MembershipOrder_userId_idx")
}

model operationlog {
  id          String   @id
  userId      String
  workspaceId String?
  action      String
  resource    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "OperationLog_userId_fkey")

  @@index([action], map: "OperationLog_action_idx")
  @@index([userId], map: "OperationLog_userId_idx")
  @@index([workspaceId], map: "OperationLog_workspaceId_idx")
}

model project {
  id          String   @id
  workspaceId String
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([status], map: "Project_status_idx")
  @@index([workspaceId], map: "Project_workspaceId_idx")
}

model smscode {
  id        String    @id
  phone     String
  code      String
  type      String    @default("reset-password")
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([code], map: "SmsCode_code_idx")
  @@index([createdAt], map: "SmsCode_createdAt_idx")
  @@index([phone], map: "SmsCode_phone_idx")
  @@index([type], map: "SmsCode_type_idx")
  @@index([used], map: "SmsCode_used_idx")
}

model systemdocument {
  id          String   @id
  title       String
  content     String?
  category    String
  tags        String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  viewCount   Int      @default(0)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  user        user?    @relation(fields: [authorId], references: [id], map: "SystemDocument_authorId_fkey")

  @@index([authorId], map: "SystemDocument_authorId_fkey")
  @@index([category], map: "SystemDocument_category_idx")
  @@index([createdAt], map: "SystemDocument_createdAt_idx")
  @@index([isPublished], map: "SystemDocument_isPublished_idx")
  @@index([sortOrder], map: "SystemDocument_sortOrder_idx")
}

model upgradeapplication {
  id           String    @id
  workspaceId  String
  userId       String
  companyName  String
  contactName  String
  contactPhone String
  phone        String?
  status       String    @default("PENDING")
  submittedAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  user         user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UpgradeApplication_userId_fkey")
  workspace    workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "UpgradeApplication_workspaceId_fkey")

  @@index([status], map: "UpgradeApplication_status_idx")
  @@index([userId], map: "UpgradeApplication_userId_fkey")
  @@index([workspaceId], map: "UpgradeApplication_workspaceId_idx")
}

model usernotification {
  id                 String   @id
  userId             String   @unique(map: "UserNotification_userId_key")
  emailNotifications Boolean  @default(true)
  systemMessages     Boolean  @default(true)
  projectUpdates     Boolean  @default(true)
  commentMentions    Boolean  @default(true)
  frequency          String   @default("REALTIME")
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  user               user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserNotification_userId_fkey")

  @@index([userId], map: "UserNotification_userId_idx")
}

model userpreference {
  id               String   @id
  userId           String   @unique(map: "UserPreference_userId_key")
  aiEngine         String   @default("zhige")
  systemPrompt     String?
  defaultModel     String   @default("zhige-v3")
  temperature      Float    @default(0.7)
  maxTokens        Int      @default(2000)
  topP             Float    @default(0.9)
  frequencyPenalty Float    @default(0)
  presencePenalty  Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  user             user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserPreference_userId_fkey")

  @@index([userId], map: "UserPreference_userId_idx")
}

model workspace {
  id                  String                @id
  name                String
  type                workspace_type
  ownerId             String
  description         String?
  logo                String?               @db.LongText
  teamSize            String?
  industry            String?
  contactEmail        String?
  contactPhone        String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  plan                String                @default("STANDARD")
  quota               Json?
  status              String                @default("ACTIVE")
  visibility          String                @default("PRIVATE")
  lastActiveAt        DateTime?
  upgradeapplication  upgradeapplication[]
  workspaceinvitation workspaceinvitation[]
  workspacemember     workspacemember[]

  @@index([lastActiveAt], map: "Workspace_lastActiveAt_idx")
  @@index([ownerId], map: "Workspace_ownerId_idx")
  @@index([plan], map: "Workspace_plan_idx")
  @@index([status], map: "Workspace_status_idx")
  @@index([type], map: "Workspace_type_idx")
}

model workspaceinvitation {
  id          String                   @id
  workspaceId String
  code        String                   @unique(map: "WorkspaceInvitation_code_key")
  createdBy   String
  email       String?
  role        workspaceinvitation_role @default(MEMBER)
  status      String                   @default("PENDING")
  expiresAt   DateTime?
  usedAt      DateTime?
  usedBy      String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime
  workspace   workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "WorkspaceInvitation_workspaceId_fkey")

  @@index([code], map: "WorkspaceInvitation_code_idx")
  @@index([createdBy], map: "WorkspaceInvitation_createdBy_idx")
  @@index([status], map: "WorkspaceInvitation_status_idx")
  @@index([workspaceId], map: "WorkspaceInvitation_workspaceId_idx")
}

model workspacemember {
  id          String               @id
  userId      String
  workspaceId String
  role        workspacemember_role
  joinedAt    DateTime             @default(now())
  user        user                 @relation(fields: [userId], references: [id], onDelete: Cascade, map: "WorkspaceMember_userId_fkey")
  workspace   workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "WorkspaceMember_workspaceId_fkey")

  @@unique([userId, workspaceId], map: "WorkspaceMember_userId_workspaceId_key")
  @@index([userId], map: "WorkspaceMember_userId_idx")
  @@index([workspaceId], map: "WorkspaceMember_workspaceId_idx")
}

enum UserStatus {
  active
  inactive
  banned
}

enum workspace_type {
  PERSONAL
  ENTERPRISE
}

enum workspacemember_role {
  OWNER
  ADMIN
  MEMBER
}

enum workspaceinvitation_role {
  OWNER
  ADMIN
  MEMBER
}
