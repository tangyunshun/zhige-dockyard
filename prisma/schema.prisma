generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 工作空间类型枚举
enum WorkspaceType {
  PERSONAL
  ENTERPRISE
}

// 工作空间角色枚举
enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model componenttask {
  id          String    @id
  name        String
  description String?
  type        String
  status      String    @default("pending")
  progress    Int       @default(0)
  config      Json?
  result      Json?
  userId      String?
  tenantId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  completedAt DateTime?
  tenant      tenant?   @relation(fields: [tenantId], references: [id], map: "ComponentTask_tenantId_fkey")
  user        user?     @relation(fields: [userId], references: [id], map: "ComponentTask_userId_fkey")

  @@index([status], map: "ComponentTask_status_idx")
  @@index([tenantId], map: "ComponentTask_tenantId_idx")
  @@index([type], map: "ComponentTask_type_idx")
  @@index([userId], map: "ComponentTask_userId_idx")
}

model tenant {
  id            String          @id
  name          String
  description   String?
  logo          String?
  status        String          @default("active")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  componenttask componenttask[]
  user          user[]

  @@index([name], map: "Tenant_name_idx")
  @@index([status], map: "Tenant_status_idx")
}

model user {
  id            String           @id @default(cuid())
  email         String?          @unique(map: "User_email_key")
  name          String?
  password      String
  phone         String?          @unique(map: "User_phone_key")
  avatar        String?
  role          String           @default("user")
  tenantId      String?
  wechatUnionId String?          @unique(map: "User_wechatUnionId_key")
  qqUnionId     String?          @unique(map: "User_qqUnionId_key")
  refreshToken  String?
  refreshTokenExpiresAt DateTime?
  loginAttempts Int              @default(0)
  lockedUntil   DateTime?
  status        String           @default("active")
  lastWorkspaceId String?        @map("last_workspace_id")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  componenttask componenttask[]
  tenant        tenant?          @relation(fields: [tenantId], references: [id], map: "User_tenantId_fkey")
  workspaces    WorkspaceMember[]

  @@index([email], map: "User_email_idx")
  @@index([phone], map: "User_phone_idx")
  @@index([tenantId], map: "User_tenantId_idx")
  @@index([status], map: "User_status_idx")
  @@index([role], map: "User_role_idx")
  @@index([lastWorkspaceId], map: "User_lastWorkspaceId_idx")
}

// 工作空间模型
model Workspace {
  id          String            @id @default(cuid())
  name        String
  type        WorkspaceType
  ownerId     String
  description String?
  logo        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]

  @@index([ownerId], map: "Workspace_ownerId_idx")
  @@index([type], map: "Workspace_type_idx")
}

// 工作空间成员关联表
model WorkspaceMember {
  id          String         @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole
  joinedAt    DateTime       @default(now())
  user        user           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "WorkspaceMember_userId_fkey")
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "WorkspaceMember_workspaceId_fkey")

  @@unique([userId, workspaceId], map: "WorkspaceMember_userId_workspaceId_key")
  @@index([userId], map: "WorkspaceMember_userId_idx")
  @@index([workspaceId], map: "WorkspaceMember_workspaceId_idx")
}

// API Key 模型
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  keyHash     String
  keyPrefix   String
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId], map: "ApiKey_userId_idx")
  @@index([keyPrefix], map: "ApiKey_keyPrefix_idx")
}

// 用户通知设置
model UserNotification {
  id                 String   @id @default(cuid())
  userId             String
  emailNotifications Boolean  @default(true)
  systemMessages     Boolean  @default(true)
  projectUpdates     Boolean  @default(true)
  commentMentions    Boolean  @default(true)
  frequency          String   @default("REALTIME") // REALTIME | DAILY | WEEKLY
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId], map: "UserNotification_userId_key")
  @@index([userId], map: "UserNotification_userId_idx")
}

// 登录历史
model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  location  String?
  device    String?
  loginAt   DateTime @default(now())

  @@index([userId], map: "LoginHistory_userId_idx")
  @@index([loginAt], map: "LoginHistory_loginAt_idx")
}

// 用户偏好设置
model UserPreference {
  id            String   @id @default(cuid())
  userId        String
  aiEngine      String   @default("zhige") // zhige | openai | azure
  systemPrompt  String?
  defaultModel  String   @default("zhige-v3")
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(2000)
  topP          Float    @default(0.9)
  frequencyPenalty Float @default(0.0)
  presencePenalty Float @default(0.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId], map: "UserPreference_userId_key")
  @@index([userId], map: "UserPreference_userId_idx")
}

// 集成配置
model Integration {
  id         String   @id @default(cuid())
  workspaceId String
  provider   String   // github | gitlab | gitee
  tokenHash  String
  name       String?
  configured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([workspaceId, provider], map: "Integration_workspaceId_provider_key")
  @@index([workspaceId], map: "Integration_workspaceId_idx")
}

// 升级申请
model UpgradeApplication {
  id           String   @id @default(cuid())
  workspaceId  String
  userId       String
  companyName  String
  contactName  String
  contactPhone String
  phone        String?  // 用户手机号（可选）
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED
  submittedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workspaceId], map: "UpgradeApplication_workspaceId_idx")
  @@index([status], map: "UpgradeApplication_status_idx")
}

// 操作日志
model OperationLog {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  action      String
  resource    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId], map: "OperationLog_userId_idx")
  @@index([workspaceId], map: "OperationLog_workspaceId_idx")
  @@index([action], map: "OperationLog_action_idx")
}

// 文档模型
model Document {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  content     String?
  parentId    String?
  type        String   @default("doc") // doc | folder
  status      String   @default("active") // active | archived | deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId], map: "Document_workspaceId_idx")
  @@index([parentId], map: "Document_parentId_idx")
  @@index([status], map: "Document_status_idx")
}

// 项目模型
model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      String   @default("active") // active | archived | deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId], map: "Project_workspaceId_idx")
  @@index([status], map: "Project_status_idx")
}

// 资产模型
model Asset {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        String
  url         String?
  metadata    Json?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId], map: "Asset_workspaceId_idx")
  @@index([type], map: "Asset_type_idx")
}

// 对话模型
model Conversation {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  title       String?
  messages    Json?
  model       String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId], map: "Conversation_workspaceId_idx")
  @@index([userId], map: "Conversation_userId_idx")
}
